{
  "name": "skunect-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "ci:pr": "npm run lint && npm run typecheck",
    "test:e2e": "playwright test",
    "test:e2e:pr": "playwright test --grep-invert=\"School Lifecycle\"",
    "test:e2e:lifecycle": "playwright test e2e/specs/flows/ --workers=1",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "pr:simulate": "npm run ci:pr && NEXT_PUBLIC_API_URL=/api/v1 NEXT_PUBLIC_WS_URL=/ws/messages npm run build && E2E_BASE_URL=https://dev.skunect.com E2E_API_URL=https://dev.skunect.com/api/v1 npm run test:e2e:pr",
    "pr:simulate:local": "npm run ci:pr && NEXT_PUBLIC_API_URL=/api/v1 NEXT_PUBLIC_WS_URL=/ws/messages npm run build && E2E_BASE_URL=http://localhost:3000 E2E_API_URL=http://localhost:3000/api/v1 npm run test:e2e:pr && E2E_BASE_URL=http://localhost:3000 E2E_API_URL=http://localhost:3000/api/v1 npm run test:e2e:lifecycle"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@stomp/stompjs": "^7.3.0",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@tanstack/react-table": "^8.21.3",
    "axios": "^1.13.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.575.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.2",
    "recharts": "^3.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "husky": "^9.1.7",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  }
}
